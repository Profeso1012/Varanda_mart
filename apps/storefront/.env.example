# Backend API Base URL
VITE_API_URL=http://localhost:4000/api/v1

# Tenant Domain override for Local Development
# Since local development runs on 'localhost', the backend cannot determine which 
# seller's store you are trying to view from the Host header.
# Set this to a valid custom domain or *.varanda.com domain of an existing seller.
# Note: This is only used in development mode (Vite DEV). In production, the actual 
# browser Host header is automatically used to identify the store tenant.
VITE_DEV_TENANT_DOMAIN=mystore.varanda.com
