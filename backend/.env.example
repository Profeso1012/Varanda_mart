# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development   # development | production | test

# ─── Database ─────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (or any PostgreSQL URL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use a long random string in production: openssl rand -hex 64
JWT_ACCESS_SECRET=your_jwt_secret_min_32_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30

# ─── Email — Brevo SMTP (primary) ─────────────────────────────────────────────
# Get from: https://app.brevo.com → SMTP & API → SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_smtp_login@smtp-brevo.com
SMTP_PASS=your_brevo_smtp_password

# Brevo API key (fallback if SMTP fails)
# Get from: https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-your_brevo_api_key

EMAIL_FROM=noreply@yourdomain.com
FROM_NAME=Varanda

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Paystack ─────────────────────────────────────────────────────────────────
# Get from: https://dashboard.paystack.com → Settings → API Keys
# Use test keys for development, live keys for production
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
# Webhook secret — set in Paystack dashboard → Settings → Webhooks
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# ─── Flutterwave (Phase 2 — subscription billing) ─────────────────────────────
# Get from: https://dashboard.flutterwave.com → Settings → API
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_flutterwave_secret
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your_flutterwave_public
# Webhook hash — set in Flutterwave dashboard → Settings → Webhooks
FLUTTERWAVE_WEBHOOK_HASH=your_flutterwave_webhook_hash
# Pre-create subscription plans in Flutterwave dashboard and paste the plan IDs here
FLUTTERWAVE_MONTHLY_PRO_PLAN_ID=
FLUTTERWAVE_YEARLY_PRO_PLAN_ID=
FLUTTERWAVE_MONTHLY_GROWTH_PLAN_ID=
FLUTTERWAVE_YEARLY_GROWTH_PLAN_ID=

# ─── Shipbubble (Phase 6 — shipping) ──────────────────────────────────────────
# Get from: https://shipbubble.com → Developer → API Keys
SHIPBUBBLE_API_URL=https://api.shipbubble.com/v1
SHIPBUBBLE_ENCRYPTION_KEY=your_shipbubble_webhook_secret

# ─── Termii (Phase 7 — SMS OTP) ───────────────────────────────────────────────
# Get from: https://termii.com → Settings → API Key
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=VARANDA

# ─── Platform rates ───────────────────────────────────────────────────────────
# Silent markup added to supplier prices before showing to sellers/developers
PLATFORM_MARKUP_RATE=0.02
# Service fee added to every customer checkout (visible to customer)
PLATFORM_SERVICE_FEE_RATE=0.0025

# ─── Encryption ───────────────────────────────────────────────────────────────
# Used to encrypt stored API keys (Stripe, Flutterwave custom, Shipbubble)
# Must be at least 32 characters. Generate: openssl rand -hex 32
ENCRYPTION_KEY=your_32_char_encryption_key_here_change_this

# ─── App URLs ─────────────────────────────────────────────────────────────────
BASE_DOMAIN=varanda.com
API_BASE_URL=https://api.varanda.com
SELLER_DASHBOARD_URL=https://app.varanda.com
DEVELOPER_PORTAL_URL=https://developers.varanda.com

# ─── Dev only ─────────────────────────────────────────────────────────────────
# Fixed OTP for Postman testing. REMOVE in production (leave empty = random OTPs).
OTP_FIXED_VALUE=654321
